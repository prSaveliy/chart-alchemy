// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     Int @id @default(autoincrement())
  email                  String @unique
  password               String?
  sub                    String? @unique
  isActivated            Boolean
  accountActivationToken AccountActivationToken?
  refreshToken           RefreshToken[]
  resetPasswordToken     ResetPasswordToken[]
}

model AccountActivationToken {
  id            Int @id @default(autoincrement())
  user          User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int? @unique
  pendingUser   PendingUser? @relation(fields: [pendingUserId], references: [id], onDelete: Cascade)
  pendingUserId Int? @unique
  token         String @unique
  expiresAt     DateTime
}

model RefreshToken {
  id        Int @id @default(autoincrement())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  token     String @unique
  expiresAt DateTime
}

model ResetPasswordToken {
  id        Int @id @default(autoincrement())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  token     String @unique
  expiresAt DateTime
}

// used as a temporary user until email confirmation in case the user
// was previously authenticated with OAuth 2.0
model PendingUser {
  id                     Int @id @default(autoincrement())
  email                  String @unique
  password               String
  accountActivationToken AccountActivationToken?
}